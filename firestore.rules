rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{playerId} {
      // อ่านได้ทุกคน (ต้องการสำหรับ real-time sync)
      allow read: if true;

      // เขียนได้เฉพาะ field ที่กำหนด และ name ต้องไม่เกิน 40 ตัวอักษร
      allow create: if request.resource.data.keys().hasOnly(['name', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 40;

      allow update: if request.resource.data.keys().hasOnly(['name', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 40;

      allow delete: if true;
    }
  }
}
